# ==========================================================================
# SKATEHIVE 3.0 - ENVIRONMENT VARIABLES
# ==========================================================================
# Copy this file to .env.local and fill in your values
# Only secrets or deployment overrides should live here
# ===========================================================================

# ==========================================================================
# APP CONFIG OVERRIDES (optional)
# ==========================================================================
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_IPFS_GATEWAY=ipfs.skatehive.app
NEXT_PUBLIC_THEME=skatehive

# ==========================================================================
# HIVE (server-only secrets)
# ==========================================================================
HIVE_POSTING_KEY=
HIVE_ACCOUNT_CREATOR=
HIVE_ACTIVE_KEY=
DEFAULT_HIVE_POSTING_ACCOUNT=skateuser
DEFAULT_HIVE_POSTING_KEY=
# ☝️ Fallback only (local dhive fallback)

# SkateHive API consolidated posting service (preferred)
SKATEHIVE_API_URL=https://api.skatehive.app
SKATEHIVE_API_KEY=

# Sponsorship system (optional - uses defaults from config/app.config.ts)
HIVE_DEFAULT_RECOVERY_ACCOUNT=skatehive
HIVE_API_NODES=https://api.hive.blog,https://api.deathwing.me,https://rpc.ecency.com

# ==========================================================================
# WEB3 / DAO
# ==========================================================================
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_ALCHEMY_KEY=
NEXT_PUBLIC_ONCHAINKIT_API_KEY=
NEXT_PUBLIC_DAO_GRAPHQL_URL=https://api.goldsky.com/api/public/project_cm33ek8kjx6pz010i2c3w8z25/subgraphs/nouns-builder-base-mainnet/latest/gn

# ==========================================================================
# ZORA
# ==========================================================================
NEXT_PUBLIC_ZORA_API_KEY=

# ==========================================================================
# SUPABASE / DATABASE
# ==========================================================================
DATABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLIC_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ==========================================================================
# SIGNUP SIGNER / VIP
# ==========================================================================
SIGNER_URL=
SIGNER_TOKEN=
NEXT_PUBLIC_SIGNER_URL=
NEXT_PUBLIC_SIGNER_TOKEN=
VIP_PEPPER=
JWT_SECRET=

# ==========================================================================
# EMAIL / SMTP
# ==========================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_RECOVERYACC=

# ==========================================================================
# PINATA / IPFS
# ==========================================================================
PINATA_JWT=

# ==========================================================================
# THIRD-PARTY
# ==========================================================================
GIPHY_API_KEY=

# ==========================================================================
# ADMIN / CRON
# ==========================================================================
ADMIN_USERS=
NEXT_PUBLIC_ADMIN_USERS=
USERBASE_INTERNAL_TOKEN=

# CRITICAL: Master secret for encrypting Hive posting keys (sponsorship system)
# Generate with: openssl rand -hex 32
# Never commit this value - keep it secret and rotate regularly
USERBASE_KEY_ENCRYPTION_SECRET=

USERBASE_ALERT_WEBHOOK_URL=

# ==========================================================================
# SYSTEM (auto-populated in deployment)
# ==========================================================================
# NODE_ENV=development
# VERCEL=1
